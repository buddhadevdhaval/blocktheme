{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "ambrygen/hero-section",
  "title": "Hero Section",
  "category": "ambrygen",
  "icon": "cover-image",
  "description": "Hero section with slider, logo overlay, rounded background images, and dual call-to-action buttons.",
  "supports": {
    "html": false
  },
  "keywords": [
    "hero",
    "banner",
    "slider",
    "carousel"
  ],
  "attributes": {
    "slides": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "backgroundImage": {
            "type": "string",
            "default": ""
          },
          "backgroundImageId": {
            "type": "integer",
            "default": 0
          },
          "backgroundImageAlt": {
            "type": "string",
            "default": ""
          },
          "overlayImage1": {
            "type": "string",
            "default": ""
          },
          "overlayImage1Id": {
            "type": "integer",
            "default": 0
          },
          "overlayImage1Alt": {
            "type": "string",
            "default": ""
          },
          "overlayImage2": {
            "type": "string",
            "default": ""
          },
          "overlayImage2Id": {
            "type": "integer",
            "default": 0
          },
          "overlayImage2Alt": {
            "type": "string",
            "default": ""
          },
          "eyebrow": {
            "type": "string",
            "default": ""
          },
          "headingTag": {
            "type": "string",
            "enum": [
              "h1",
              "h2",
              "h3",
              "h4",
              "h5",
              "h6"
            ],
            "default": "h2"
          },
          "heading": {
            "type": "string",
            "default": ""
          },
          "content": {
            "type": "string",
            "default": ""
          },
          "tagline": {
            "type": "string",
            "default": ""
          },
          "primarybutton": {
            "type": "object",
            "properties": {
              "url": {
                "type": "string",
                "default": ""
              },
              "text": {
                "type": "string",
                "default": ""
              },
              "target": {
                "type": "string",
                "default": ""
              },
              "rel": {
                "type": "string",
                "default": ""
              },
              "variant": {
                "type": "string",
                "default": ""
              }
            }
          },
          "secondarybutton": {
            "type": "object",
            "properties": {
              "url": {
                "type": "string",
                "default": ""
              },
              "text": {
                "type": "string",
                "default": ""
              },
              "target": {
                "type": "string",
                "default": ""
              },
              "rel": {
                "type": "string",
                "default": ""
              },
              "variant": {
                "type": "string",
                "default": ""
              }
            }
          }
        }
      },
      "default": [
        {
          "backgroundImage": "",
          "backgroundImageId": 0,
          "backgroundImageAlt": "",
          "overlayImage1": "",
          "overlayImage1Id": 0,
          "eyebrow": "",
          "overlayImage1Alt": "",
          "headingTag": "h2",
          "overlayImage2": "",
          "overlayImage2Id": 0,
          "overlayImage2Alt": "",
          "heading": "Industry-leading genetic testing",
          "content": "For over 25 years our high-quality, accessible genetic testing solutions have shaped important care decisions that patients and families make with their healthcare providers.",
          "buttonPrimaryText": "Start Your Order",
          "buttonPrimaryUrl": "#",
          "buttonSecondaryText": "Who We Are",
          "buttonSecondaryUrl": "#",
          "primarybutton": {
            "url": "",
            "text": "",
            "target": "",
            "rel": "",
            "variant": ""
          },
          "secondarybutton": {
            "url": "",
            "text": "",
            "target": "",
            "rel": "",
            "variant": ""
          }
        }
      ]
    },
    "showSliderNav": {
      "type": "boolean",
      "default": true
    },
    "showSliderDots": {
      "type": "boolean",
      "default": true
    },
    "autoplay": {
      "type": "boolean",
      "default": true
    },
    "autoplayDelay": {
      "type": "number",
      "default": 5000
    }
  },
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "render": "file:./render.php",
  "viewScript": "file:./view.js",
  "textdomain": "ambrygen-web",
  "example": {
    "attributes": {
      "slides": [
        {
          "backgroundImage": "",
          "backgroundImageId": 0,
          "backgroundImageAlt": "",
          "overlayImage1": "",
          "overlayImage1Id": 0,
          "eyebrow": "",
          "overlayImage1Alt": "",
          "headingTag": "h2",
          "overlayImage2": "",
          "overlayImage2Id": 0,
          "overlayImage2Alt": "",
          "heading": "Industry-leading genetic testing",
          "content": "For over 25 years our high-quality, accessible genetic testing solutions have shaped important care decisions that patients and families make with their healthcare providers.",
          "tagline": "This brings the Ambry mindset to life: a relentless pursuit to find the answers.",
          "buttonPrimaryText": "Start Your Order",
          "buttonPrimaryUrl": "#",
          "buttonSecondaryText": "Who We Are",
          "buttonSecondaryUrl": "#",
          "primarybutton": {
            "url": "",
            "text": "",
            "target": "",
            "rel": "",
            "variant": ""
          },
          "secondarybutton": {
            "url": "",
            "text": "",
            "target": "",
            "rel": "",
            "variant": ""
          }
        }
      ],
      "showSliderNav": true,
      "showSliderDots": true,
      "autoplay": true,
      "autoplayDelay": 5000
    }
  }
}