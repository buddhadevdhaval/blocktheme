{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "ambrygen/genetic-testing-card",
  "title": "Genetic Testing Card",
  "category": "ambrygen",
  "parent": [
    "ambrygen/genetic-testing-cards"
  ],
  "icon": "format-image",
  "description": "An individual card for genetic testing.",
  "supports": {
    "html": false,
    "color": {
      "background": true,
      "text": true,
      "link": true
    },
    "spacing": {
      "margin": true,
      "padding": true,
      "blockGap": true
    },
    "typography": {
      "fontSize": true,
      "lineHeight": true
    }
  },
  "attributes": {
    "image": {
      "type": "string",
      "default": ""
    },
    "imageId": {
      "type": "number",
      "default": 0
    },
    "imageAlt": {
      "type": "string",
      "default": ""
    },
    "title": {
      "type": "string",
      "default": ""
    },
    "description": {
      "type": "string",
      "default": ""
    },
    "link": {
      "type": "object",
      "default": {
        "url": "",
        "text": "",
        "target": "",
        "rel": "",
        "variant": ""
      }
    },
    "type": {
      "type": "string",
      "default": "small"
    },
    "imageSrcSet": {
      "type": "string"
    },
    "imageSizes": {
      "type": "string"
    }
  },
  "textdomain": "ambrygen-web",
  "editorScript": "file:./index.js",
  "render": "file:./render.php",
  "example": {
    "attributes": {
      "image": "/wp-content/themes/ambrygen/assets/src/images/ambrygen-default-image.png",
      "imageId": 0,
      "imageAlt": "Ambry default preview image",
      "title": "Sample Title",
      "description": "This is a sample preview content for this block in the inserter.",
      "link": {
        "url": "#",
        "text": "Sample text",
        "target": "_self",
        "rel": "",
        "variant": "primary"
      },
      "type": "small",
      "imageSrcSet": "",
      "imageSizes": ""
    }
  }
}