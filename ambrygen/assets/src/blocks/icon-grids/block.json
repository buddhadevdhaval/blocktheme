{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "ambrygen/icon-grids",
  "title": "Icon Grids",
  "category": "ambrygen",
  "icon": "grid-view",
  "description": "Grid layout for icon cards with contact information",
  "supports": {
    "html": false,
    "layout": {
      "allowSwitching": true,
      "allowInheriting": true
    }
  },
  "attributes": {
    "heading": {
      "type": "string",
      "default": ""
    },
    "headingTag": {
      "type": "string",
      "default": "h2"
    },
    "description": {
      "type": "string",
      "default": ""
    },
    "variation": {
      "type": "string",
      "default": "two-column"
    },
    "blockId": {
      "type": "string"
    },
    "link": {
      "type": "object",
      "default": {
        "url": "",
        "text": "",
        "target": "",
        "rel": "",
        "variant": ""
      }
    },
    "selectedTabs": {
      "type": "array",
      "default": [
        {
          "text": "All Tests",
          "termSlug": "all"
        }
      ]
    }
  },
  "providesContext": {
    "ambrygen/variation": "variation"
  },
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "viewScript": "file:./view.js",
  "textdomain": "ambrygen-web",
  "render": "file:./render.php",
  "example": {
    "attributes": {
      "heading": "Title",
      "headingTag": "h2",
      "description": "This is a sample preview content for this block in the inserter.",
      "variation": "two-column",
      "blockId": "1",
      "link": {
        "url": "Sample url",
        "text": "Sample text",
        "target": "Sample target",
        "rel": "Sample rel",
        "variant": "Sample variant"
      }
    }
  }
}
